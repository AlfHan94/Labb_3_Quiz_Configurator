<UserControl x:Class="Labb_3_Quiz_Configurator.Views.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="AnswerButton" TargetType="Button">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Background" Value="#E3E3E3"/>
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1200">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="{Binding TimeRemaining}"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0 20 40 0"/>
            
            <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <TextBlock Text="{Binding CurrentQuestion.Query}"
                       FontSize="38"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <TextBlock HorizontalAlignment="Center" FontSize="20" Margin="0 0 0 40">
                    <Run Text="Question "/>
                    <Run Text="{Binding CurrentQuestionIndex, Mode=OneWay}"/>
                    <Run Text=" of "/>
                    <Run Text="{Binding ActivePack.Questions.Count, Mode=OneWay}"/>
            </TextBlock>

                <UniformGrid Rows="2" Columns="2" HorizontalAlignment="Center">
                    <Button Content="{Binding ShuffledAnswers[0]}"
                        Command="{Binding AnswerCommand}"
                        CommandParameter="{Binding ShuffledAnswers[0]}"
                        Style="{StaticResource AnswerButton}"/>
                    <Button Content="{Binding ShuffledAnswers[1]}"
                        Command="{Binding AnswerCommand}"
                        CommandParameter="{Binding ShuffledAnswers[1]}"
                        Style="{StaticResource AnswerButton}"/>
                    <Button Content="{Binding ShuffledAnswers[2]}"
                        Command="{Binding AnswerCommand}"
                        CommandParameter="{Binding ShuffledAnswers[2]}"
                        Style="{StaticResource AnswerButton}"/>
                    <Button Content="{Binding ShuffledAnswers[3]}"
                        Command="{Binding AnswerCommand}"
                        CommandParameter="{Binding ShuffledAnswers[3]}"
                        Style="{StaticResource AnswerButton}"/>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Viewbox>
</UserControl>
