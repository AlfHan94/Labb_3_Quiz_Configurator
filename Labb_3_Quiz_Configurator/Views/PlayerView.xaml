<UserControl x:Class="Labb_3_Quiz_Configurator.Views.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Labb_3_Quiz_Configurator.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:AnswerStateToBrushConverter x:Key="AnswerStateBrush"/>
        <Style x:Key="AnswerButton" TargetType="Button">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="2"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsAnswering}" Value="True"/>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#D8D8D8"/>
                            </MultiDataTrigger>

                            <DataTrigger Binding="{Binding ShowFeedback}" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource AnswerStateBrush}">
                                            <Binding Path="ShowFeedback"/>
                                            <Binding Path="Content" RelativeSource="{RelativeSource TemplatedParent}"/>
                                            <Binding Path="CorrectAnswer"/>
                                            <Binding Path="SelectedAnswer"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>


    <Viewbox Stretch="Uniform">
        <Grid Width="1200">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding TimeRemaining}"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0 20 40 0"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">

                <TextBlock Text="{Binding CurrentQuestion.Query}"
                           FontSize="38"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <TextBlock HorizontalAlignment="Center" FontSize="20" Margin="0 0 0 40">
                    <Run Text="Question "/>
                    <Run Text="{Binding CurrentQuestionIndex, Mode=OneWay}"/>
                    <Run Text=" of "/>
                    <Run Text="{Binding ActivePack.Questions.Count, Mode=OneWay}"/>
                </TextBlock>

                <UniformGrid Rows="2" Columns="2" HorizontalAlignment="Center">

                    <Button Content="{Binding ShuffledAnswers[0]}"
                            Command="{Binding AnswerCommand}"
                            CommandParameter="{Binding ShuffledAnswers[0]}"
                            Style="{StaticResource AnswerButton}"/>

                    <Button Content="{Binding ShuffledAnswers[1]}"
                            Command="{Binding AnswerCommand}"
                            CommandParameter="{Binding ShuffledAnswers[1]}"
                            Style="{StaticResource AnswerButton}"/>

                    <Button Content="{Binding ShuffledAnswers[2]}"
                            Command="{Binding AnswerCommand}"
                            CommandParameter="{Binding ShuffledAnswers[2]}"
                            Style="{StaticResource AnswerButton}"/>

                    <Button Content="{Binding ShuffledAnswers[3]}"
                            Command="{Binding AnswerCommand}"
                            CommandParameter="{Binding ShuffledAnswers[3]}"
                            Style="{StaticResource AnswerButton}"/>

                </UniformGrid>
            </StackPanel>
        </Grid>
    </Viewbox>

</UserControl>
