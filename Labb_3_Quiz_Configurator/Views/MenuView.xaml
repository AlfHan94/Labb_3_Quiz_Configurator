<UserControl x:Class="Labb_3_Quiz_Configurator.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Labb_3_Quiz_Configurator.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Menu>
        <MenuItem Header="_File">
            <MenuItem Header="_New Question Pack"
                      Command="{Binding ConfigurationViewModel.OpenNewQuestionPackCommand}"
                      />
            <MenuItem Header="_Select Question Pack" ItemsSource="{Binding DataContext.Packs, RelativeSource={RelativeSource AncestorType=Window}}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Name}"/>
                        <Setter Property="Command"
                                Value="{Binding DataContext.SetActivePackCommand, RelativeSource={RelativeSource AncestorType=Menu}}"/>
                        <Setter Property="CommandParameter" Value="{Binding}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>

            <MenuItem Header="Delete Question Pack"/>
            <Separator/>
            <MenuItem Header="Import Questions" InputGestureText="Ctrl+I"/>
            <Separator/>
            <MenuItem Header="E_xit" InputGestureText="Alt+F4" />
        </MenuItem>
        <MenuItem Header="_Edit">
            <MenuItem Header="Add Question" InputGestureText="Insert"
                      Command="{Binding DataContext.ConfigurationViewModel.AddQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <MenuItem Header="Remove Question" InputGestureText="Delete"
                      Command="{Binding DataContext.ConfigurationViewModel.RemoveQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Separator/>
            <MenuItem Header="Pack Options"
                      Command="{Binding ConfigurationViewModel.OpenPackOptionsCommand}"
                      InputGestureText="Ctrl+O"/>
      
        </MenuItem>
        <MenuItem Header="_View">

            <MenuItem Header="Play" InputGestureText="Ctrl+P"/>
            <MenuItem Header="Edit" InputGestureText="Ctrl+E"/>
            <Separator/>
            <MenuItem Header="Fullscreen" InputGestureText="Ctrl+F"/>
            
            </MenuItem>

    </Menu>
            
    
</UserControl>
