<UserControl x:Class="Labb_3_Quiz_Configurator.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Labb_3_Quiz_Configurator.Views"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Menu>
        <MenuItem Header="_File">
            <MenuItem Header="_New Question Pack"
                      Icon="{fa:Icon FileCirclePlus}"
                      Command="{Binding DataContext.ConfigurationViewModel.OpenNewQuestionPackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      />
            <MenuItem Header="_Select Question Pack"
                      Icon="{fa:Icon FolderOpen}"
                      ItemsSource="{Binding DataContext.Packs, RelativeSource={RelativeSource AncestorType=Window}}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Name}"/>
                        <Setter Property="Command"
                                Value="{Binding DataContext.SetActivePackCommand, RelativeSource={RelativeSource AncestorType=Menu}}"/>
                        <Setter Property="CommandParameter" Value="{Binding}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
            <MenuItem Header="Delete Question Pack"
                      Icon="{fa:Icon Trash}"
                      />
            <Separator/>
            <MenuItem Header="Import Questions"
                      Icon="{fa:Icon FileArrowUp}"
                      InputGestureText="Ctrl+I"/>
            <Separator/>
            <MenuItem Header="E_xit"
                      Icon="{fa:Icon DoorOpen}"
                      InputGestureText="Alt+F4" />
        </MenuItem>
        
        <MenuItem Header="_Edit">
            <MenuItem Header="Add Question"
                      Icon="{fa:Icon Plus}"
                      InputGestureText="Insert"
                      Command="{Binding DataContext.ConfigurationViewModel.AddQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <MenuItem Header="Remove Question"
                      Icon="{fa:Icon Minus}"
                      InputGestureText="Delete"
                      Command="{Binding DataContext.ConfigurationViewModel.RemoveQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Separator/>
            <MenuItem Header="Pack Options"
                      Icon="{fa:Icon Gear}"
                      InputGestureText="Ctrl+O"
                      Command="{Binding DataContext.ConfigurationViewModel.OpenPackOptionsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      />
        </MenuItem>
        
        <MenuItem Header="_View">
            <MenuItem Header="Play"
                      Icon="{fa:Icon Play}"
                      InputGestureText="Ctrl+P"
                      Command="{Binding DataContext.ShowPlayerViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <MenuItem Header="Edit"
                      Icon="{fa:Icon PenToSquare}"
                      InputGestureText="Ctrl+E"
                      Command="{Binding DataContext.ShowConfigurationViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Separator/>
            <MenuItem Header="Fullscreen"
                      Icon="{fa:Icon Expand}"
                      InputGestureText="Ctrl+F"
                      Command="{Binding DataContext.ToggleFullscreenCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </MenuItem>
    </Menu>
</UserControl>
