<UserControl x:Class="Labb_3_Quiz_Configurator.Views.ConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Labb_3_Quiz_Configurator.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             DataContext="{Binding ConfigurationViewModel}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel HorizontalAlignment="Stretch" Grid.Row="0" Grid.Column="0">
            <Label Content="{Binding ActivePack.Name}" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="20" 
                        Margin="5"
                        FontFamily="Segoe MDL2 Assets"
                        Content="&#xE713;"
                        Command="{Binding OpenPackOptionsCommand}"/>
                
                <Button Width="20" 
                        Margin="5" 
                        FontFamily="Segoe MDL2 Assets"
                        Content="&#xE710;" 
                        Command="{Binding AddQuestionCommand}"/>
                
                <Button Width="20"
                        Margin="5"
                        FontFamily="Segoe MDL2 Assets"
                        Content="&#xE738;"
                        Command="{Binding RemoveQuestionCommand}"/>
            </StackPanel>
        </DockPanel>
        <ListBox Grid.Row="1" Margin="5" ItemsSource="{Binding ActivePack.Questions}"
                 DisplayMemberPath="Query" SelectedItem="{Binding ActiveQuestion}"/>

        <StackPanel Orientation="Vertical" Grid.Column="1" Grid.RowSpan="2">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveQuestion}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Label Content="Question:" FontWeight="Bold"/>
            <TextBox Height="100" Margin="5 0 30 0" Text="{Binding ActiveQuestion.Query}"/>
            <Label Content="Correct Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.CorrectAnswer}"/>
            <Label Content="First Incorrect Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.IncorrectAnswers[0]}"/>
            <Label Content="Second Incorrect Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.IncorrectAnswers[1]}"/>
            <Label Content="Third Incorrect Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.IncorrectAnswers[2]}"/>

        </StackPanel>

    </Grid>
</UserControl>
