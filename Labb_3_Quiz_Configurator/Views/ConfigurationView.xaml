<UserControl x:Class="Labb_3_Quiz_Configurator.Views.ConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Labb_3_Quiz_Configurator.Views"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Height="30" HorizontalAlignment="Stretch" Grid.Row="0" Grid.Column="0">
            <Label Content="{Binding ActivePack.Name}" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="18" Margin="5"
                        Command="{Binding OpenPackOptionsCommand}" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <fa:IconBlock Icon="Gear" Width="14" Height="14">
                        <fa:IconBlock.RenderTransform>
                            <TranslateTransform Y="1"/>
                        </fa:IconBlock.RenderTransform>
                    </fa:IconBlock>
                </Button>
                <Button Width="18" Margin="5"
                        Command="{Binding AddQuestionCommand}" Height="18">
                    <fa:IconBlock Icon="Plus" Width="14" Height="14"/>
                </Button>
                <Button Width="18" Margin="5"
                        Command="{Binding RemoveQuestionCommand}" Height="18">
                    <fa:IconBlock Icon="Minus" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </DockPanel>
        <ListBox Grid.Row="1" Margin="2 0 5 2" ItemsSource="{Binding ActivePack.Questions}"
                 DisplayMemberPath="Query" SelectedItem="{Binding ActiveQuestion}"/>
        <StackPanel Orientation="Vertical" Grid.Column="1" Grid.RowSpan="2">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveQuestion}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Label Content="Question:" FontWeight="Bold"/>
            <TextBox Height="100" Margin="5 0 30 0" Text="{Binding ActiveQuestion.Query}"/>
            <Label Content="Correct Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.CorrectAnswer}"/>
            <Label Content="First Incorrect Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.IncorrectAnswers[0]}"/>
            <Label Content="Second Incorrect Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.IncorrectAnswers[1]}"/>
            <Label Content="Third Incorrect Answer:" FontWeight="Bold"/>
            <TextBox Margin="5 0 30 0" Text="{Binding ActiveQuestion.IncorrectAnswers[2]}"/>
        </StackPanel>

    </Grid>
</UserControl>
