<Window x:Class="Labb_3_Quiz_Configurator.Dialogs.CreateNewPackDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Labb_3_Quiz_Configurator.Models"
        Title="New Question Pack"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">



    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

       
        <TextBlock Text="Pack Name:" FontWeight="Bold"/>
        <TextBox Grid.Row="1" Width="200" Margin="0 4 0 10"
                 Text="{Binding Name}"/>
        
        <TextBlock Grid.Row="2" Text="Difficulty:" FontWeight="Bold"/>
        <ComboBox Grid.Row="3" Width="200" Margin="0 4 0 10"
          SelectedItem="{Binding Difficulty}"
          ItemsSource="{x:Static models:DifficultyEnumValues.All}"/>

        <StackPanel Grid.Row="4" Orientation="Vertical">
            <TextBlock Text="Time Limit:" FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 2 0 0">
                <Slider Width="150"
                Minimum="5" Maximum="120" TickFrequency="5"
                IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                Value="{Binding TimeLimitInSeconds}"/>
                <TextBlock Text="{Binding TimeLimitInSeconds}" Margin="8 0 2 0"/>
                <TextBlock Text="seconds"/>
            </StackPanel>
        </StackPanel>
        
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 0">
            <Button Content="Cancel" Width="75" Margin="0 0 30 0" IsCancel="True"/>
            <Button Content="Create" Width="75" IsDefault="True" Click="OnCreateClicked"/>
        </StackPanel>
        

    </Grid>

</Window>
